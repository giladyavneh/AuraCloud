# Port the API server listens on. Defaults to 3000 if unset.
PORT=3000

# Optional. Public-facing URL of this server, used only for the startup log.
# Local dev: leave unset (the server logs http://localhost:<PORT>).
# Staging / production: set to the deployed URL (e.g. https://api.auracloud.com).
PUBLIC_URL=

# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=Cluster0
