{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "utils": ["../utils/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../utils" }
  ]
}
