# AWS credentials (or use IAM role / AWS SSO session instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS region for the crawlers (defaults to eu-central-1 if unset)
AWS_REGION=eu-central-1

# Optional: target account ID override (auto-detected via STS if unset)
TARGET_ACCOUNT_ID=

# MongoDB Atlas connection string — same value as in api-server/.env
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=Cluster0

# Redis connection (defaults to localhost:6379 if all unset)
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
